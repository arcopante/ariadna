# ── Configuración del robot ───────────────────────────────────
# Copia este fichero como .env y rellena tus valores:
#   cp .env.example .env
#
# El fichero .env está en .gitignore y nunca se sube al repositorio.

# API de Anthropic (obligatorio para el módulo de IA)
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX

# Puerto serie del Arduino
# Linux: /dev/ttyUSB0 o /dev/ttyACM0
# Comprobar con: ls /dev/tty*
SERIAL_PORT=/dev/ttyUSB0

# Índice de la cámara USB
# Comprobar con: v4l2-ctl --list-devices
CAMERA_INDEX=0

# FPS objetivo de la cámara (el Odroid-C2 aguanta bien hasta 10-15)
CAMERA_FPS=10

# Resolución de captura
CAMERA_WIDTH=320
CAMERA_HEIGHT=240

# Distancia mínima en cm antes de frenar por obstáculo
OBSTACLE_CM=25

# Tensión mínima de batería en mV antes de parar (LiPo 2S ~6500mV)
BATTERY_LOW_MV=6500

# Intervalo en segundos entre consultas al LLM
LLM_INTERVAL_S=3.0

# Modelo LLM a usar (haiku es el más rápido y barato para el bucle)
LLM_MODEL=claude-haiku-4-5-20251001
